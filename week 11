      "source": [
        "students = {}\n",
        "total = 0\n",
        "count = 0\n",
        "\n",
        "while True:\n",
        "  name = input(\"enter student name(or'done'): \")\n",
        "  if name.lower() == 'done':\n",
        "    break\n",
        "\n",
        "  while True: # Loop to ensure valid grade input\n",
        "    try:\n",
        "      grade_input = input(f\"enter {name}'s grade: \")\n",
        "      grade = float(grade_input)\n",
        "      break # Exit inner loop if grade is valid\n",
        "    except ValueError:\n",
        "      print(\"Invalid grade. Please enter a single numerical value.\")\n",
        "\n",
        "  students[name] = grade\n",
        "  total += grade\n",
        "  count += 1\n",
        "\n",
        "  print(\"\\n--- Class Report ---\")\n",
        "  for name, grade in students.items():\n",
        "    print(f\"{name}: {grade}\")\n",
        "\n",
        "  if count > 0:\n",
        "    average = total / count\n",
        "    print(f\"Class Average: {average:.2f}\")\n",
        "  else:\n",
        "    print(\"No students entered.\")"
      ],
