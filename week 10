        "players = []\n",
        "\n",
        "# Input loop\n",
        "while True:\n",
        "  name = input(\"enter player name (or 'quit' to stop):\")\n",
        "\n",
        "  if name.lower() == \"quit\":\n",
        "    break\n",
        "\n",
        "  players.append(name)\n",
        "\n",
        "#search\n",
        "search_name = input(\"\\nwgo would you like to search for? \")\n",
        "if search_name in players:\n",
        "  print(\"Result: Player found!\")\n",
        "else:\n",
        "  print(\"Result: Player not found.\")"
